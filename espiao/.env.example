NODE_ENV=development

# API
API_PORT=3001
JWT_SECRET=change-me-in-development
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-refresh-in-development
JWT_REFRESH_EXPIRES_IN=7d
WEB_APP_URL=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_audit?schema=public

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Meta WhatsApp Business Cloud API oficial
META_WHATSAPP_API_VERSION=v21.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=

# Webhook
ENABLE_WEBHOOK_RAW_LOG=false
# WhatsApp provider: meta_cloud_api | session_provider
WHATSAPP_PROVIDER=meta_cloud_api

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Risco mínimo para gerar alerta (0-100). Padrão: 70
AI_ANALYSIS_RISK_THRESHOLD=70
