# Variáveis para desenvolvimento local — copiar para .env.local
# Em produção, configurar no painel da Vercel

# URL da API REST
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL do servidor socket.io (normalmente igual à API URL)
# Se omitido, herda o valor de NEXT_PUBLIC_API_URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
